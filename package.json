{
	"name": "guardrail-blocks",
	"version": "0.1.0",
	"description": "Accessibility-first blocks with WCAG-safe color contrast and unbreakable heading hierarchy — enforced by design.",
	"author": "Breon Williams",
	"license": "GPL-2.0-or-later",
	"private": true,
	"scripts": {
		"build": "wp-scripts build --experimental-modules --blocks-manifest",
		"start": "wp-scripts start --experimental-modules --blocks-manifest",
		"format": "wp-scripts format",
		"lint:js": "wp-scripts lint-js",
		"lint:style": "wp-scripts lint-style",
		"check-types": "tsc --noEmit",
		"test:unit": "wp-scripts test-unit-js --passWithNoTests",
		"test:e2e": "playwright test",
		"env:start": "wp-env start",
		"env:stop": "wp-env stop",
		"plugin-zip": "wp-scripts plugin-zip"
	},
	"files": [
		"guardrail-blocks.php",
		"includes",
		"build",
		"src",
		"package.json",
		"tsconfig.json",
		"readme.txt"
	],
	"devDependencies": {
		"@playwright/test": "^1.61.1",
		"@types/jest": "^30.0.0",
		"@wordpress/block-editor": "^15.23.0",
		"@wordpress/blocks": "^15.23.0",
		"@wordpress/components": "^36.1.0",
		"@wordpress/data": "^10.50.0",
		"@wordpress/e2e-test-utils-playwright": "^1.50.0",
		"@wordpress/editor": "^14.50.0",
		"@wordpress/element": "^8.2.0",
		"@wordpress/env": "^10.39.0",
		"@wordpress/plugins": "^7.50.0",
		"@wordpress/i18n": "^6.23.0",
		"@wordpress/interactivity": "^6.50.0",
		"@wordpress/scripts": "^30.0.0",
		"typescript": "^5.5.0"
	}
}
