{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "guardrail-blocks/table-of-contents",
	"version": "0.1.1",
	"title": "Table of Contents",
	"category": "design",
	"icon": "list-view",
	"description": "A table of contents generated from the page's real heading outline on every view — reorder your sections and it stays correct, automatically.",
	"keywords": [ "toc", "table of contents", "outline", "navigation", "accessible" ],
	"textdomain": "guardrail-blocks",
	"attributes": {},
	"usesContext": [ "postId" ],
	"supports": {
		"html": false,
		"anchor": true,
		"spacing": {
			"margin": true,
			"padding": true
		},
		"typography": {
			"fontSize": true
		}
	},
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
